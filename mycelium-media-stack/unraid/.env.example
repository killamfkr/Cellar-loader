# TorBox API key — https://torbox.app → Settings → API
TORBOX_API_KEY=replace-me

# TMDB Read Access Token (starts with eyJ)
TMDB_API_KEY=replace-me

# Your Unraid LAN URL for Mycelium Catbox proxy
CATBOX_HOST=http://192.168.1.50:8088

# Random secret for Seerr → Mycelium webhook
WEBHOOK_SECRET=change-me-to-a-random-string

# Optional — fill after Seerr setup
SEERR_API_KEY=

# Optional Plex claim — https://www.plex.tv/claim/
PLEX_CLAIM=

# Unraid defaults (nobody:users)
PUID=99
PGID=100
TZ=UTC
